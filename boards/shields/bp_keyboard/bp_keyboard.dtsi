/*
 * Copyright (c) 2026 BP Keyboard
 * SPDX-License-Identifier: MIT
 * BP分体键盘 - 统一矩阵定义
 * 矩阵: 18列 x 6行 (左9列 + 右9列)
 * 矩阵: 18列 x 6逻辑行 (物理行重映射)
 * 物理行索引: 0=ROW0(D10),1=ROW1(D18),2=ROW2(D19),3=ROW3(D20),4=ROW4(D21),5=ROW5(D3)
 * 逻辑行顺序: 行0=物理ROW5(功能行), 行1=物理ROW0(数字行), 行2=物理ROW1, 行3=物理ROW2, 行4=物理ROW3, 行5=物理ROW4(拇指区)
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include "bp_keyboard-layouts.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical_layout = &physical_layout0;
    };

    matrix_transform0: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <18>;
        rows = <6>;
        map = <
        //  左键盘                      												 		      右键盘
        // 顶部功能行 (KLE 第一行)
        RC(5,1)  RC(5,2)  RC(5,3)  RC(5,4)  RC(5,5)  RC(5,6)  RC(5,7)  RC(5,8)                    RC(5,9)  RC(5,10) RC(5,11) RC(5,12) RC(5,13) RC(5,14) RC(5,15) RC(5,16)

        // 主键盘区第 0 行 (KLE 第二行)
        RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)  RC(0,7)   RC(0,8)          RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17)

        // 主键盘区第 1 行 (KLE 第三行)
        RC(1,0)  RC(1,1)  RC(1,2)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)                    RC(1,9)  RC(4,10) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) RC(1,16) RC(1,17)

        // 主键盘区第 2 行 (KLE 第四行)
        RC(2,0)  RC(2,1)  RC(2,2)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)                    RC(2,9)  RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) RC(2,16) RC(2,17)

        // 主键盘区第 3 行 (KLE 第五行)
        RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,7) RC(3,8)            RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15) RC(3,16) RC(3,17)

        // 主键盘区第 4 行 (KLE 第六行)
        RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,5)  RC(4,7)  RC(4,8)                             RC(4,9)  RC(4,11) RC(4,12) RC(4,13) RC(4,14) RC(4,15) RC(4,16) RC(4,17)
        >;
    };

    kscan0: kscan_matrix_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        wakeup-source;
        diode-direction = "col2row";

        // 行线定义（左右共用）
        row-gpios
            = <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW0
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW1
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW2
            , <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW3
            , <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW4
            , <&pro_micro 3  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // ROW5
            ;

        // col-gpios 由各 overlay 定义
    };
};